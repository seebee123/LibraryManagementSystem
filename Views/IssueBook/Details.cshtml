@model LibraryManagementSystem.Models.IssueBook

@{
    ViewData["Title"] = "Issue Details";
}

<div class="container mt-4">

    <h2 class="text-info mb-4">📖 Issue Book Details</h2>

    <div class="card shadow-sm p-4">

        <div class="row mb-2">
            <div class="col-md-3"><strong>Student Name:</strong></div>
            <div class="col-md-9">@Model.Student?.Name</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Book Title:</strong></div>
            <div class="col-md-9">@Model.Book?.Title</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Issue Date:</strong></div>
            <div class="col-md-9">@Model.IssueDate.ToShortDateString()</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Due Date:</strong></div>
            <div class="col-md-9">@Model.DueDate.ToShortDateString()</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Return Date:</strong></div>
            <div class="col-md-9">
                @(Model.ReturnDate.HasValue
                    ? Model.ReturnDate.Value.ToShortDateString()
                    : "Not Returned")
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Fine:</strong></div>
            <div class="col-md-9">₹ @Model.Fine</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Status:</strong></div>
            <div class="col-md-9">
                @if (Model.Status == "Issued")
                {
                    <span class="text-danger">Issued</span>
                }
                else
                {
                    <span class="text-success">Returned</span>
                }
            </div>
        </div>

    </div>

    <div class="mt-3">

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>

    </div>

</div>