@model LibraryManagementSystem.Models.IssueBook

@{
    ViewData["Title"] = "Issue Details";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                📖 Issue Details
            </h3>

        </div>

        <div class="card-body">

            <!-- Issue Type -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Issue Type
                </div>

                <div class="col-md-9">

                    @if (Model.IssueType == "Student")
                    {
                        <span class="badge bg-primary">
                            👨‍🎓 Student
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success">
                            👨‍🏫 Teacher
                        </span>
                    }

                </div>

            </div>

            <!-- Issued To -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Issued To
                </div>

                <div class="col-md-9">

                    @if (Model.IssueType == "Student")
                    {
                        <strong>@Model.Student?.Name</strong>

                        <br />

                        <small class="text-muted">
                            Roll No :
                            @Model.Student?.RollNo
                        </small>
                    }
                    else
                    {
                        <strong>@Model.Teacher?.Name</strong>

                        <br />

                        <small class="text-muted">
                            Employee ID :
                            @Model.Teacher?.EmployeeId
                        </small>
                    }

                </div>

            </div>

            <!-- Book -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Book
                </div>

                <div class="col-md-9">
                    @Model.Book?.Title
                </div>

            </div>

            <!-- Issue Date -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Issue Date
                </div>

                <div class="col-md-9">
                    @Model.IssueDate.ToString("dd-MM-yyyy")
                </div>

            </div>

            <!-- Due Date -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Due Date
                </div>

                <div class="col-md-9">
                    @Model.DueDate.ToString("dd-MM-yyyy")
                </div>

            </div>

            <!-- Return Date -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Return Date
                </div>

                <div class="col-md-9">

                    @(Model.ReturnDate.HasValue
                        ? Model.ReturnDate.Value.ToString("dd-MM-yyyy")
                        : "Not Returned")

                </div>

            </div>

            <!-- Fine -->
            <div class="row mb-3">

                <div class="col-md-3 fw-bold">
                    Fine
                </div>

                <div class="col-md-9">
                    ₹ @Model.Fine
                </div>

            </div>

            <!-- Status -->
            <div class="row mb-4">

                <div class="col-md-3 fw-bold">
                    Status
                </div>

                <div class="col-md-9">

                    @if (Model.Status == "Issued")
                    {
                        <span class="badge bg-danger">
                            Issued
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success">
                            Returned
                        </span>
                    }

                </div>

            </div>

            <a asp-action="Index"
               class="btn btn-secondary">

                ← Back

            </a>

        </div>

    </div>

</div>