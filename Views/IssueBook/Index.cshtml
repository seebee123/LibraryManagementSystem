@model IEnumerable<LibraryManagementSystem.Models.IssueBook>

@{
    ViewData["Title"] = "Issued Books";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">

        <h2 class="text-primary fw-bold">
            📚 Issued Books List
        </h2>

        <div>

            <a asp-action="ExportExcel"
               class="btn btn-success me-2">
                <i class="bi bi-file-earmark-excel-fill"></i>
                Export Excel
            </a>

            <a asp-action="Create"
               class="btn btn-primary">
                ➕ Issue New Book
            </a>

        </div>

    </div>

    <!-- SUCCESS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <strong>Success!</strong> @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <!-- SEARCH -->
    <form asp-action="Index" method="get" class="mb-4">

        <div class="row">

            <div class="col-md-8">
                <input type="text"
                       name="searchString"
                       value="@Context.Request.Query["searchString"]"
                       class="form-control"
                       placeholder="🔍 Search by Roll No, Student, Book or Status..." />
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    Search
                </button>
            </div>

            <div class="col-md-2 d-grid">
                <a asp-action="Index" class="btn btn-secondary">
                    Clear
                </a>
            </div>

        </div>

    </form>

    <!-- TABLE -->
    <div class="table-responsive">

        <table class="table table-bordered table-hover table-striped">

            <thead class="table-dark">
                <tr>
                    <th>Student</th>
                    <th>Book</th>
                    <th>Issue Date</th>
                    <th>Due Date</th>
                    <th>Return Date</th>
                    <th>Fine (₹)</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                <span class="badge bg-primary">
                                    @item.Student?.RollNo
                                </span>
                                <br />
                                @item.Student?.Name
                            </td>

                            <td>@item.Book?.Title</td>

                            <td>@item.IssueDate.ToString("dd-MM-yyyy")</td>

                            <td>@item.DueDate.ToString("dd-MM-yyyy")</td>

                            <td>
                                @(item.ReturnDate.HasValue
                                    ? item.ReturnDate.Value.ToString("dd-MM-yyyy")
                                    : "-")
                            </td>

                            <td>₹ @item.Fine</td>

                            <td>
                                @if (item.Status == "Issued")
                                {
                                    <span class="badge bg-danger">Issued</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Returned</span>
                                }
                            </td>

                            <td>

                                @if (item.Status == "Issued")
                                {
                                    <a asp-action="Return"
                                       asp-route-id="@item.IssueId"
                                       class="btn btn-warning btn-sm">
                                        Return
                                    </a>
                                }

                                <a asp-action="Delete"
                                   asp-route-id="@item.IssueId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete?')">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-danger fw-bold">
                            No records found.
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-center mt-3">

        <nav>
            <ul class="pagination">

                @for (int i = 1; i <= (ViewBag.TotalPages ?? 1); i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { page = i, searchString = Context.Request.Query["searchString"] })">
                            @i
                        </a>
                    </li>
                }

            </ul>
        </nav>

    </div>

</div>