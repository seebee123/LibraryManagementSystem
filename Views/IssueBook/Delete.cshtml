@model LibraryManagementSystem.Models.IssueBook

@{
    ViewData["Title"] = "Delete Issue Record";
}

<div class="container mt-4">

    <h2 class="text-danger mb-4">🗑 Delete Issue Record</h2>

    <div class="alert alert-warning">
        ⚠️ Are you sure you want to delete this record?
    </div>

    <div class="card p-3 mb-3 shadow-sm">

        <p><strong>Student:</strong> @Model.Student?.Name</p>

        <p><strong>Book:</strong> @Model.Book?.Title</p>

        <p><strong>Issue Date:</strong> @Model.IssueDate.ToShortDateString()</p>

        <p><strong>Due Date:</strong> @Model.DueDate.ToShortDateString()</p>

        <p>
            <strong>Status:</strong>
            @if (Model.Status == "Issued")
            {
                <span class="text-danger">Issued</span>
            }
            else
            {
                <span class="text-success">Returned</span>
            }
        </p>

        <p><strong>Fine:</strong> ₹ @Model.Fine</p>

    </div>

    <form asp-action="Delete" method="post">

        <input type="hidden" asp-for="IssueId" />

        <button type="submit" class="btn btn-danger">
            🗑 Yes, Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>