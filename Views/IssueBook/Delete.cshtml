@model LibraryManagementSystem.Models.IssueBook

@{
    ViewData["Title"] = "Delete Issue Record";
}

<div class="container mt-4">

    <h2 class="text-danger mb-4">
        🗑 Delete Issue Record
    </h2>

    <div class="alert alert-warning">
        ⚠️ Are you sure you want to delete this issue record?
    </div>

    <div class="card shadow-sm p-4">

        <!-- Issue Type -->
        <p>
            <strong>Issue Type:</strong>

            @if (Model.IssueType == "Student")
            {
                <span class="badge bg-primary">
                    👨‍🎓 Student
                </span>
            }
            else
            {
                <span class="badge bg-success">
                    👨‍🏫 Teacher
                </span>
            }
        </p>

        <!-- Student / Teacher -->
        @if (Model.IssueType == "Student")
        {
            <p>
                <strong>Student:</strong>
                @Model.Student?.Name
                (@Model.Student?.RollNo)
            </p>
        }
        else
        {
            <p>
                <strong>Teacher:</strong>
                @Model.Teacher?.Name
                (@Model.Teacher?.EmployeeId)
            </p>
        }

        <!-- Book -->
        <p>
            <strong>Book:</strong>
            @Model.Book?.Title
        </p>

        <!-- Issue Date -->
        <p>
            <strong>Issue Date:</strong>
            @Model.IssueDate.ToString("dd-MM-yyyy")
        </p>

        <!-- Due Date -->
        <p>
            <strong>Due Date:</strong>
            @Model.DueDate.ToString("dd-MM-yyyy")
        </p>

        <!-- Return Date -->
        <p>
            <strong>Return Date:</strong>

            @(Model.ReturnDate.HasValue
                ? Model.ReturnDate.Value.ToString("dd-MM-yyyy")
                : "Not Returned")
        </p>

        <!-- Status -->
        <p>

            <strong>Status:</strong>

            @if (Model.Status == "Issued")
            {
                <span class="badge bg-danger">
                    Issued
                </span>
            }
            else
            {
                <span class="badge bg-success">
                    Returned
                </span>
            }

        </p>

        <!-- Fine -->
        <p>
            <strong>Fine:</strong>
            ₹ @Model.Fine
        </p>

    </div>

    <form asp-action="Delete" method="post" class="mt-4">

        <input type="hidden" asp-for="IssueId" />

        <button type="submit" class="btn btn-danger">
            🗑 Yes, Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>