@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>

    body {
        transition: .3s;
    }

    .dark-mode {
        background: #1e1e1e;
        color: white;
    }

        .dark-mode .card {
            background: #2b2b2b;
            color: white;
        }

    .card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .card {
        border: none;
        border-radius: 18px;
        transition: .3s;
        cursor: pointer;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,.18);
        }

    /* ================= HEADER ================= */

    .dashboard-header {
        background: #ffffff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,.08);
        transition: .3s;
    }

    .dark-mode .dashboard-header {
        background: #2c2c2c;
    }

    .dashboard-title {
        font-size: 30px;
        font-weight: 700;
    }

    .datetime {
        font-size: 18px;
        font-weight: 600;
    }

    .system-status {
        color: #28a745;
        font-weight: bold;
        margin-top: 5px;
    }

    .welcome-title {
        font-size: 28px;
        font-weight: 700;
    }

    .color-btn {
        width: 22px;
        height: 22px;
        border: none;
        border-radius: 50%;
        padding: 0;
        cursor: pointer;
    }

    .top-btn {
        border-radius: 10px;
        padding: 9px 18px;
    }

    .logout-btn {
        border-radius: 10px;
        padding: 9px 18px;
    }

    .card h5 {
        font-size: 17px;
        font-weight: 600;
    }

    .card h2 {
        font-size: 34px;
        font-weight: bold;
    }

</style>

<div class="container mt-4">

    <!-- ================= HEADER ================= -->

    <div class="dashboard-header mb-4" id="dashboardHeader">

        <div class="row align-items-center">
            <!-- LEFT -->

            <div class="col-lg-4">

                <h2 class="dashboard-title">
                    🏠 Library Admin Dashboard
                </h2>

            </div>

            <!-- CENTER -->

            <div class="col-lg-4 text-center">

                <div class="datetime">

                    📅 <span id="currentDate"></span>

                </div>

                <div class="datetime mt-1">

                    🕒 <span id="currentTime"></span>

                </div>

                <div class="system-status">

                    🟢 System Online

                </div>

            </div>

            <!-- RIGHT -->

            <div class="col-lg-4">

                <div class="d-flex justify-content-end align-items-center gap-2">

                    <!-- Theme -->

                    <button class="btn btn-dark top-btn"
                            onclick="toggleTheme()">

                        🌙 Theme

                    </button>

                    <!-- Header Color Picker -->

                    <button class="color-btn"
                            style="background:#0d6efd;"
                            onclick="changeHeader('#0d6efd')">
                    </button>

                    <button class="color-btn"
                            style="background:#198754;"
                            onclick="changeHeader('#198754')">
                    </button>

                    <button class="color-btn"
                            style="background:#dc3545;"
                            onclick="changeHeader('#dc3545')">
                    </button>

                    <button class="color-btn"
                            style="background:#6f42c1;"
                            onclick="changeHeader('#6f42c1')">
                    </button>

                    <button class="color-btn"
                            style="background:#fd7e14;"
                            onclick="changeHeader('#fd7e14')">
                    </button>

                    <button class="color-btn"
                            style="background:#212529;"
                            onclick="changeHeader('#212529')">
                    </button>

                    <!-- Logout -->

                    <button class="btn btn-danger logout-btn"
                            data-bs-toggle="modal"
                            data-bs-target="#logoutModal">

                        <i class="bi bi-box-arrow-right"></i>

                        Logout

                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- ================= WELCOME ================= -->

    <div class="mb-4">

        <h3 class="welcome-title text-primary">

            👋 Welcome,
            @Context.Session.GetString("User")

        </h3>

    </div>

    <!-- ================= DASHBOARD CARDS ================= -->

    <div class="row">
        <!-- ================= BOOKS ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="Book"
               asp-action="Index"
               class="card-link">

                <div class="card bg-primary text-white p-3">

                    <h5>📚 Books</h5>

                    <h2>@ViewBag.TotalBooks</h2>

                </div>

            </a>

        </div>

        <!-- ================= STUDENTS ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="Student"
               asp-action="Index"
               class="card-link">

                <div class="card bg-success text-white p-3">

                    <h5>👨‍🎓 Students</h5>

                    <h2>@ViewBag.TotalStudents</h2>

                </div>

            </a>

        </div>

        <!-- ================= TEACHERS ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="Teacher"
               asp-action="Index"
               class="card-link">

                <div class="card bg-info text-white p-3">

                    <h5>👨‍🏫 Teachers</h5>

                    <h2>@ViewBag.TotalTeachers</h2>

                </div>

            </a>

        </div>

        <!-- ================= TOTAL ISSUED ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="IssueBook"
               asp-action="Index"
               class="card-link">

                <div class="card bg-warning text-dark p-3">

                    <h5>📖 Total Issued</h5>

                    <h2>@ViewBag.IssuedBooks</h2>

                </div>

            </a>

        </div>
        <!-- ================= STUDENT ISSUES ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="IssueBook"
               asp-action="Index"
               class="card-link">

                <div class="card bg-secondary text-white p-3">

                    <h5>👨‍🎓 Student Issues</h5>

                    <h2>@ViewBag.StudentIssues</h2>

                </div>

            </a>

        </div>

        <!-- ================= TEACHER ISSUES ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="IssueBook"
               asp-action="Index"
               class="card-link">

                <div class="card bg-dark text-white p-3">

                    <h5>👨‍🏫 Teacher Issues</h5>

                    <h2>@ViewBag.TeacherIssues</h2>

                </div>

            </a>

        </div>

        <!-- ================= OVERDUE BOOKS ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="IssueBook"
               asp-action="Overdue"
               class="card-link">

                <div class="card bg-danger text-white p-3">

                    <h5>🔴 Overdue Books</h5>

                    <h2>@ViewBag.OverdueBooks</h2>

                </div>

            </a>

        </div>

        <!-- ================= RETURNED BOOKS ================= -->

        <div class="col-lg-3 col-md-6 mb-3">

            <a asp-controller="IssueBook"
               asp-action="Index"
               class="card-link">

                <div class="card bg-success text-white p-3">

                    <h5>🔄 Returned Books</h5>

                    <h2>@ViewBag.ReturnedBooks</h2>

                </div>

            </a>

        </div>

    </div>
    <!-- ================= TOTAL FINE ================= -->

    <div class="row mt-4">

        <div class="col-lg-4">

            <div class="card border-start border-5 border-danger shadow-sm p-4">

                <h5>

                    💰 Total Fine Collected

                </h5>

                <h2 class="text-danger fw-bold">

                    ₹ @ViewBag.TotalFine

                </h2>

            </div>

        </div>

    </div>

    <hr class="my-4" />

    <!-- ================= QUICK ACTIONS ================= -->

    <h4 class="fw-bold mb-3">

        ⚡ Quick Actions

    </h4>

    <div class="mb-4">

        <!-- ================= CREATE ================= -->

        <a class="btn btn-primary m-1"
           asp-controller="Student"
           asp-action="Create">

            ➕ Add Student

        </a>

        <a class="btn btn-success m-1"
           asp-controller="Teacher"
           asp-action="Create">

            👨‍🏫 Add Teacher

        </a>

        <a class="btn btn-warning m-1"
           asp-controller="Book"
           asp-action="Create">

            📚 Add Book

        </a>

        <a class="btn btn-danger m-1"
           asp-controller="IssueBook"
           asp-action="Create">

            📖 Issue Book

        </a>

        <br /><br />
        <!-- ================= VIEW BUTTONS ================= -->

        <a class="btn btn-dark m-1"
           asp-controller="Student"
           asp-action="Index">

            👨‍🎓 View Students

        </a>

        <a class="btn btn-dark m-1"
           asp-controller="Teacher"
           asp-action="Index">

            👨‍🏫 View Teachers

        </a>

        <a class="btn btn-dark m-1"
           asp-controller="Book"
           asp-action="Index">

            📚 View Books

        </a>

        <a class="btn btn-dark m-1"
           asp-controller="IssueBook"
           asp-action="Index">

            📊 Issued Records

        </a>

        <a class="btn btn-danger m-1"
           asp-controller="IssueBook"
           asp-action="Overdue">

            🔴 Overdue Books

        </a>

        <br /><br />

        <!-- ================= EXPORT BUTTONS ================= -->

        <a class="btn btn-success m-1"
           asp-controller="Book"
           asp-action="ExportExcel">

            📄 Export Books

        </a>

        <a class="btn btn-primary m-1"
           asp-controller="Student"
           asp-action="ExportExcel">

            📄 Export Students

        </a>

        <a class="btn btn-info m-1"
           asp-controller="Teacher"
           asp-action="ExportExcel">

            📄 Export Teachers

        </a>

        <a class="btn btn-warning text-dark m-1"
           asp-controller="IssueBook"
           asp-action="ExportExcel">

            📄 Export Issued Books

        </a>

    </div>
    <!-- ================= LOGOUT MODAL ================= -->

    <div class="modal fade"
         id="logoutModal"
         tabindex="-1"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content shadow-lg border-0">

                <div class="modal-header bg-danger text-white">

                    <h5 class="modal-title">

                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Confirm Logout

                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body text-center">

                    <i class="bi bi-box-arrow-right text-danger"
                       style="font-size:70px;"></i>

                    <h3 class="mt-3 fw-bold">

                        Logout?

                    </h3>

                    <p class="text-muted">

                        Are you sure you want to logout from the
                        <br />

                        <strong>Library Management System</strong>?

                    </p>

                </div>

                <div class="modal-footer justify-content-center">

                    <button class="btn btn-secondary"
                            data-bs-dismiss="modal">

                        Cancel

                    </button>

                    <a asp-controller="Login"
                       asp-action="Logout"
                       class="btn btn-danger">

                        <i class="bi bi-box-arrow-right"></i>

                        Yes, Logout

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

    // ===============================
    // LIVE DATE & TIME
    // ===============================

    function updateDateTime() {

    const now = new Date();

    const dateOptions = {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric'
    };

    const timeOptions = {
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit'
    };

    document.getElementById("currentDate").innerHTML =
    now.toLocaleDateString('en-IN', dateOptions);

    document.getElementById("currentTime").innerHTML =
    now.toLocaleTimeString('en-IN', timeOptions);

    }

    updateDateTime();

    setInterval(updateDateTime, 1000);


    // ===============================
    // DARK MODE
    // ===============================

    function toggleTheme() {

    document.body.classList.toggle("dark-mode");

    }


    // ===============================
    // HEADER COLOR CHANGER
    // ===============================

    function changeHeader(color) {

    const header = document.getElementById("dashboardHeader");

    header.style.background = color;

    header.style.color = "white";

    localStorage.setItem("headerColor", color);

    }


    // ===============================
    // LOAD SAVED HEADER COLOR
    // ===============================

    window.onload = function () {

    const savedColor = localStorage.getItem("headerColor");

    if (savedColor) {

    const header = document.getElementById("dashboardHeader");

    header.style.background = savedColor;

    header.style.color = "white";

    }

    };

</script>
