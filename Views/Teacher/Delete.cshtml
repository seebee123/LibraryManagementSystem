@model LibraryManagementSystem.Models.Teacher

@{
    ViewData["Title"] = "Delete Teacher";
}

<div class="container mt-4">

    <div class="card shadow border-danger">

        <div class="card-header bg-danger text-white">

            <h3 class="mb-0">
                🗑️ Delete Teacher
            </h3>

        </div>

        <div class="card-body">

            <div class="alert alert-warning">

                <h5>
                    Are you sure you want to delete this teacher?
                </h5>

                <p class="mb-0">
                    This action cannot be undone.
                </p>

            </div>

            <table class="table table-bordered">

                <tr>
                    <th width="200">Employee ID</th>
                    <td>@Model.EmployeeId</td>
                </tr>

                <tr>
                    <th>Name</th>
                    <td>@Model.Name</td>
                </tr>

                <tr>
                    <th>Department</th>
                    <td>@Model.Department</td>
                </tr>

                <tr>
                    <th>Designation</th>
                    <td>@Model.Designation</td>
                </tr>

                <tr>
                    <th>Email</th>
                    <td>@Model.Email</td>
                </tr>

                <tr>
                    <th>Phone</th>
                    <td>@Model.Phone</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>@Model.Status</td>
                </tr>

            </table>

            <form asp-action="Delete">

                <input type="hidden" asp-for="TeacherId" />

                <button type="submit"
                        class="btn btn-danger">

                    🗑️ Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    ← Cancel

                </a>

            </form>

        </div>

    </div>

</div>
