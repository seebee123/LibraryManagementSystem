@model LibraryManagementSystem.Models.Teacher

@{
    ViewData["Title"] = "Teacher Details";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">

            <h3 class="mb-0">
                👨‍🏫 Teacher Details
            </h3>

        </div>

        <div class="card-body">

            <table class="table table-bordered table-striped">

                <tr>
                    <th width="220">Employee ID</th>
                    <td>@Model.EmployeeId</td>
                </tr>

                <tr>
                    <th>Name</th>
                    <td>@Model.Name</td>
                </tr>

                <tr>
                    <th>Department</th>
                    <td>@Model.Department</td>
                </tr>

                <tr>
                    <th>Designation</th>
                    <td>@Model.Designation</td>
                </tr>

                <tr>
                    <th>Email</th>
                    <td>@Model.Email</td>
                </tr>

                <tr>
                    <th>Phone</th>
                    <td>@Model.Phone</td>
                </tr>

                <tr>
                    <th>Address</th>
                    <td>@Model.Address</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>
                        @if (Model.Status == "Active")
                        {
                            <span class="badge bg-success">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Inactive
                            </span>
                        }
                    </td>
                </tr>

            </table>

            <a asp-action="Edit"
               asp-route-id="@Model.TeacherId"
               class="btn btn-warning">
                ✏️ Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                ← Back to List
            </a>

        </div>

    </div>

</div>
