@model LibraryManagementSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">

    <h2 class="text-danger mb-4">🗑 Delete Student</h2>

    <div class="alert alert-warning">
        ⚠️ Are you sure you want to delete this student?
    </div>

    <div class="card p-3 mb-3">

        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Roll No:</strong> @Model.RollNo</p>
        <p><strong>Department:</strong> @Model.Department</p>
        <p><strong>Semester:</strong> @Model.Semester</p>
        <p><strong>Email:</strong> @Model.Email</p>

    </div>

    <form asp-action="Delete" method="post">

        <input type="hidden" asp-for="StudentId" />

        <button type="submit" class="btn btn-danger">
            🗑 Yes, Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>