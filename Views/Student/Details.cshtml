@model LibraryManagementSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">

    <h2 class="text-info mb-4">👁 Student Details</h2>

    <div class="card shadow-sm p-4">

        <div class="row mb-2">
            <div class="col-md-3"><strong>Name:</strong></div>
            <div class="col-md-9">@Model.Name</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Roll No:</strong></div>
            <div class="col-md-9">@Model.RollNo</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Department:</strong></div>
            <div class="col-md-9">@Model.Department</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Semester:</strong></div>
            <div class="col-md-9">@Model.Semester</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Admission Year:</strong></div>
            <div class="col-md-9">@Model.AdmissionYear</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Email:</strong></div>
            <div class="col-md-9">@Model.Email</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Phone:</strong></div>
            <div class="col-md-9">@Model.Phone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3"><strong>Address:</strong></div>
            <div class="col-md-9">@Model.Address</div>
        </div>

    </div>

    <div class="mt-3">

        <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-warning">
            ✏ Edit
        </a>

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>

    </div>

</div>