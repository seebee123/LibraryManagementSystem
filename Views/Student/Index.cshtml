@model IEnumerable<LibraryManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="text-primary fw-bold">
            🎓 Students
        </h2>

        <div>

            <a asp-action="ExportExcel"
               class="btn btn-success me-2">
                📄 Export Excel
            </a>

            <a asp-action="Create"
               class="btn btn-primary">
                ➕ Add Student
            </a>

        </div>

    </div>

    <!-- SUCCESS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["Success"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    <!-- SEARCH -->
    <form asp-action="Index" method="get" class="mb-4">

        <div class="row">

            <div class="col-md-8">
                <input type="text"
                       name="searchString"
                       value="@Context.Request.Query["searchString"]"
                       class="form-control"
                       placeholder="Search by Name, Roll No, Department or Email..." />
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    🔍 Search
                </button>
            </div>

            <div class="col-md-2 d-grid">
                <a asp-action="Index" class="btn btn-secondary">
                    Clear
                </a>
            </div>

        </div>

    </form>

    <!-- TABLE -->
    <table class="table table-bordered table-hover table-striped">

        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Roll No</th>
                <th>Semester</th>
                <th>Department</th>
                <th>Email</th>
                <th width="200">Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Name</td>
                    <td>@item.RollNo</td>
                    <td>@item.Semester</td>
                    <td>@item.Department</td>
                    <td>@item.Email</td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.StudentId"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.StudentId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.StudentId"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

    <!-- PAGINATION -->
    <nav class="mt-3">
        <ul class="pagination">

            @if (ViewBag.TotalPages != null)
            {
                for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">

                        <a class="page-link"
                           href="?page=@i&searchString=@Context.Request.Query["searchString"]">
                            @i
                        </a>

                    </li>
                }
            }

        </ul>
    </nav>

</div>