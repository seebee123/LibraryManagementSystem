<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - Library Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>

            body {
                transition: 0.3s;
            }

            /* Sidebar */
            .sidebar {
                width: 220px;
                height: 100vh;
                position: fixed;
                background: #111;
                color: white;
                padding-top: 20px;
            }

                .sidebar a {
                    display: block;
                    color: white;
                    padding: 12px;
                    text-decoration: none;
                    transition: 0.3s;
                }

                    .sidebar a:hover {
                        background: #0d6efd;
                        transform: translateX(5px);
                    }

            /* Main content */
            .main {
                margin-left: 230px;
                padding: 20px;
            }

            /* Cards animation */
            .card {
                transition: 0.3s;
            }

                .card:hover {
                    transform: scale(1.05);
                }

            /* Dark mode */
            .dark-mode {
                background: #1e1e1e;
                color: white;
            }

                .dark-mode .card {
                    background: #2c2c2c;
                    color: white;
                }

    </style>

</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="text-center">📚 Library</h4>

        <a href="/Home/Index">🏠 Dashboard</a>
        <a href="/Student">👨‍🎓 Students</a>
        <a href="/Book">📚 Books</a>
        <a href="/IssueBook">📖 Issued</a>
    </div>

    <!-- Main Content -->
    <div class="main">

        <!-- Top Bar -->
        <div class="d-flex justify-content-between mb-3">

            <h3>@ViewData["Title"]</h3>

            <div>

                <!-- Dark Mode -->
                <button class="btn btn-dark btn-sm" onclick="toggleTheme()">
                    🌙 Theme
                </button>

                <!-- Color Theme -->
                <button class="btn btn-primary btn-sm" onclick="changeColor('#0d6efd')"></button>
                <button class="btn btn-success btn-sm" onclick="changeColor('#198754')"></button>
                <button class="btn btn-danger btn-sm" onclick="changeColor('#dc3545')"></button>

            </div>

        </div>

        @RenderBody()

    </div>

    <script>

            function toggleTheme() {
                document.body.classList.toggle("dark-mode");
            }

            function changeColor(color) {
                document.querySelector(".sidebar").style.background = color;

                document.querySelectorAll(".sidebar a").forEach(el => {
                    el.style.background = "transparent";
                });
            }

    </script>

    <!-- 🔥 IMPORTANT FIX (Scripts Section Error Solve) -->
    @RenderSection("Scripts", required: false)

</body>
</html>