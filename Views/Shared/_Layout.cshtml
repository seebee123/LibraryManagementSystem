<!DOCTYPE html>
<html>
<head>

    <title>@ViewData["Title"] - Library Admin</title>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <style>

            body {
                transition: .3s;
                overflow-x: hidden;
            }

            /* ==========================
                       SIDEBAR
                    ===========================*/

            .sidebar {
                width: 220px;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: #111;
                color: white;
                padding-top: 20px;
                transition: .3s;
            }

                .sidebar h4 {
                    margin-bottom: 25px;
                    font-weight: bold;
                }

                .sidebar a {
                    display: block;
                    color: white;
                    text-decoration: none;
                    padding: 12px 18px;
                    transition: .30s;
                    font-size: 16px;
                }

                    .sidebar a:hover {
                        background: #0d6efd;
                        transform: translateX(6px);
                    }

            /* ==========================
                       MAIN
                    ===========================*/

            .main {
                margin-left: 230px;
                padding: 25px;
            }

            /* ==========================
                       CARD
                    ===========================*/

            .card {
                transition: .30s;
            }

                .card:hover {
                    transform: translateY(-4px);
                }

            /* ==========================
                       DARK MODE
                    ===========================*/

            .dark-mode {
                background: #1e1e1e;
                color: white;
            }

                .dark-mode .card {
                    background: #2b2b2b;
                    color: white;
                }

                .dark-mode .sidebar {
                    background: #000;
                }

    </style>

</head>

<body>

    <!-- ================= SIDEBAR ================= -->

    <div class="sidebar">

        <h4 class="text-center">

            📚 Library

        </h4>

        <a href="/Home/Index">
            🏠 Dashboard
        </a>

        <a href="/Student">
            👨‍🎓 Students
        </a>

        <a href="/Teacher">
            👨‍🏫 Teachers
        </a>

        <a href="/Book">
            📚 Books
        </a>

        <a href="/IssueBook">
            📖 Issued
        </a>

    </div>

    <!-- ================= MAIN ================= -->

    <div class="main">

        @RenderBody()

    </div>

    @RenderSection("Scripts", required: false)

</body>

</html>